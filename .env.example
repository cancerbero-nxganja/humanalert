# HumanAlert Configuration
# Copy this file to .env and fill in your values

DATABASE_URL=postgresql://humanalert:password@db:5432/humanalert
DB_USER=humanalert
DB_PASS=change_this_password
JWT_SECRET=change_this_secret_key_min_32_chars
NODE_ENV=production

# Optional: SMS alerts via Twilio
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# Optional: Email alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional: Map tiles (default: OpenStreetMap free)
MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
